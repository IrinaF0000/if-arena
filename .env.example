# Battle Net Arena local environment example
# Copy to .env for local development. Never commit .env or real secret values.

# Backend runtime
BATTLE_SERVER_HOST=0.0.0.0
BATTLE_TCP_PORT=5555
BATTLE_WS_PORT=8081
BATTLE_LOG_LEVEL=info

# Telegram Mini App backend authentication
# Store the real bot token only in local .env, GitHub Secrets, or a cloud secret store.
BATTLE_TELEGRAM_BOT_TOKEN=REPLACE_ME_DO_NOT_COMMIT_REAL_TOKEN

# Session signing secret used after backend validates Telegram initData.
# Generate a strong random value for any shared or public deployment.
BATTLE_SESSION_SIGNING_KEY=REPLACE_ME_GENERATE_32_BYTES_OR_MORE

# TLS paths for local reverse proxy or public deployment.
# Do not commit real private keys or certificates.
BATTLE_TLS_CERT_PATH=/path/to/local/cert.pem
BATTLE_TLS_KEY_PATH=/path/to/local/key.pem

# Optional demo deployment controls
BATTLE_METRICS_LOG_EVERY_SECONDS=5
BATTLE_MAX_CONNECTIONS=1000
BATTLE_MAX_MATCHES=250
