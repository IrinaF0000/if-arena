# Placeholder Dockerfile. Update paths after real CMake targets are implemented.
FROM ubuntu:24.04

RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY battle_server /usr/local/bin/battle_server
EXPOSE 5555/tcp
CMD ["battle_server", "--host", "0.0.0.0", "--port", "5555"]
